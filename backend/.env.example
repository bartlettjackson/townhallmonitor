DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/townhall_db
ANTHROPIC_API_KEY=sk-ant-your-key-here
AUTH_SECRET_KEY=change-me-to-a-random-secret
INVITE_CODE=your-team-invite-code
ALLOWED_ORIGINS=http://localhost:3000
# Comma-separated emails allowed to perform admin actions (e.g. mint invite codes)
ADMIN_EMAILS=bartlett.jackson@gmail.com
# Trusted reverse-proxy hops in front of the app (Railway edge = 1). Controls
# which X-Forwarded-For entry is treated as the real client IP for rate limiting.
TRUSTED_PROXY_HOPS=1
SCRAPE_CRON=0 6 * * *
SCRAPE_ENABLED=true
